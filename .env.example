# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://truffl:truffl@localhost:5432/truffl
REDIS_URL=redis://localhost:6379

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_STORE_DOMAIN=

# Voice providers
VOICE_PROVIDER=mock
VOICE_PROVIDER_WEBHOOK_SECRET=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI voice / LLM
OPENAI_API_KEY=
BUILDER_LLM_PROVIDER=openai
BUILDER_LLM_MODEL=gpt-5.2

# WhatsApp provider
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# AWS / storage
AWS_REGION=ap-south-1
S3_RECORDINGS_BUCKET=
S3_TRANSCRIPTS_BUCKET=

# CRM / Sheets
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Security
SESSION_SECRET=

# Worker
WORKER_ENABLE_REDIS=false
