TWILIO_AUTH_TOKEN=

# AI voice / LLM
OPENAI_API_KEY=

# WhatsApp provider
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
WHATSAPP_WEBHOOK_SECRET=

# CRM / Sheets
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Security
SESSION_SECRET=

# Worker
WORKER_ENABLE_REDIS=false
